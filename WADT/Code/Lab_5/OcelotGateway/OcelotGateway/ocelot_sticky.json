{
  "Routes": [
    {
      "DownstreamPathTemplate": "/A",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 3000
        },
        {
          "Host": "localhost",
          "Port": 3001
        },
        {
          "Host": "localhost",
          "Port": 3002
        }
